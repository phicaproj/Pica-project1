{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"module": "node20",
		"moduleResolution": "node16",

		"target": "ES2020",

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,

		"sourceMap": true,
		"declaration": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}

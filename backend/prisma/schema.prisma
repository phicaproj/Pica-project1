generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Phase {
  PHASE1
  PHASE2A
  PHASE2B
}

enum RiskType {
  NORMAL
  RISK
  KNOCKOUT
}

enum ColorBand {
  RED
  AMBER
  GREEN
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  PAID
  REPORT_GENERATED
}

enum InsightRule {
  KNOCKOUT
  BOTH_RISK
  ONE_RISK
  BOTH_NORMAL
}

enum BusinessSize {
  SMALL
  MEDIUM
}

enum Plan {
  PHASE2A
  PHASE2B_PILLAR
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
  REVERSED
}

enum PaymentProvider {
  PAYSTACK
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

// ============================================================
// LAYER A — CONTENT (Static / Admin-Managed)
// ============================================================

model Pillar {
  id           String  @id @default(uuid())
  code         String  @unique // e.g. "FL", "FR", "BM", "OP", "MS", "GC", "SS"
  name         String // e.g. "Founder & Leadership"
  description  String?
  weight       Decimal @db.Decimal(5, 2) // e.g. 14.28 for equal 7-pillar weighting
  displayOrder Int     @map("display_order")
  isActive     Boolean @default(true) @map("is_active")

  // Relations
  questions           Question[]
  sessionPillarScores SessionPillarScore[]
  // Phase 2B: a payment / session / unlock can be scoped to one pillar.
  payments            Payment[]
  sessions            AssessmentSession[]
  phase2bUnlocks      Phase2BPillarUnlock[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pillars")
}

model Question {
  id                String       @id @default(uuid())
  pillarId          String       @map("pillar_id")
  questionCode      String       @unique @map("question_code") // e.g. "FL-001"
  questionText      String       @map("question_text")
  // A single question can serve both phases. Phase 2A draws from the full active set
  // for the user's businessSize; Phase 1 surfaces only those flagged isPhase1Featured.
  businessSize      BusinessSize @map("business_size")
  isPhase1Featured  Boolean      @default(false) @map("is_phase1_featured")
  // Which deep-dive phase this question belongs to.
  //   PHASE2A — Phase 1 and Phase 2A draw from these rows.
  //   PHASE2B — pillar-specific deep-dive content, surfaced only when a user
  //             starts a Phase 2B session for the matching pillar.
  // Existing rows default to PHASE2A so the migration is non-destructive.
  phase             Phase        @default(PHASE2A) @map("phase")
  displayOrder      Int          @map("display_order")
  hasKnockoutOption Boolean      @default(false) @map("has_knockout_option")
  isActive          Boolean      @default(true) @map("is_active")

  // Relations
  pillar    Pillar            @relation(fields: [pillarId], references: [id])
  options   QuestionOption[]
  responses SessionResponse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

model QuestionOption {
  id             String   @id @default(uuid())
  questionId     String   @map("question_id")
  optionLabel    String   @map("option_label") // "A", "B", "C", "D"
  optionText     String   @map("option_text")
  score          Int // 0, 3, 5, 6, 7, 10
  riskType       RiskType @map("risk_type")
  observation    String // e.g. "High focus"
  recommendation String // e.g. "Maintain this; you are in the Growth Zone"
  displayOrder   Int      @map("display_order")

  // Relations
  question  Question          @relation(fields: [questionId], references: [id])
  responses SessionResponse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([questionId, optionLabel]) // no duplicate A/B/C/D per question
  @@map("question_options")
}

// ============================================================
// LAYER B — USERS
// ============================================================

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String? @map("password_hash") // null for Phase 1 lead-only users
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  businessName String? @map("business_name")
  phone        String?
  isVerified   Boolean @default(false) @map("is_verified")

  // Snapshotted from the originating Phase 1 AssessmentSession at registration.
  // Source of truth for Phase 2A `businessSize` filtering.
  businessSize   BusinessSize? @map("business_size")
  staffSize      String?       @map("staff_size")
  industry       String?
  location       String?
  operatingYears String?       @map("operating_years")
  annualRevenue  String?       @map("annual_revenue_range")

  // Relations
  sessions       AssessmentSession[]
  payments       Payment[]
  phase2bUnlocks Phase2BPillarUnlock[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================================
// LAYER C — SESSION (Per User Assessment Run)
// ============================================================

model AssessmentSession {
  id     String        @id @default(uuid())
  userId String?       @map("user_id")
  phase  Phase
  status SessionStatus @default(IN_PROGRESS)

  // Phase 2B only — the pillar being deep-dived. Null for PHASE1 / PHASE2A.
  pillarId String? @map("pillar_id")

  // Phase 1 lead capture fields (filled before account creation)
  leadEmail      String?       @unique @map("lead_email")
  staffSize      String?       @map("lead_staff_size")
  businessName   String        @map("lead_business_name")
  industry       String        @map("lead_industry")
  location       String        @map("lead_location")
  operatingYears String        @map("lead_operating_years")
  annualRevenue  String        @map("lead_annual_revenue_range")
  businessSize   BusinessSize? @map("business_size")

  // Phase 2A snapshot: array of question UUIDs (length = 7 pillars × 10 = 70)
  // Frozen on Phase 2A start so admin edits to questions mid-session do not change the user's set.
  selectedQuestionIds Json? @map("selected_question_ids")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user          User?                @relation(fields: [userId], references: [id])
  pillar        Pillar?              @relation(fields: [pillarId], references: [id])
  responses     SessionResponse[]
  pillarScores  SessionPillarScore[]
  result        SessionResult?
  phase2bUnlock Phase2BPillarUnlock?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("assessment_sessions")
}

model SessionResponse {
  id               String @id @default(uuid())
  sessionId        String @map("session_id")
  questionId       String @map("question_id")
  selectedOptionId String @map("selected_option_id")

  // Captured at answer time so reports are immune to future admin edits on the question/option content.
  scoreAtTime    Int      @map("score_at_time")
  riskTypeAtTime RiskType @map("risk_type_at_time")

  answeredAt DateTime @default(now()) @map("answered_at")

  // Relations
  session        AssessmentSession @relation(fields: [sessionId], references: [id])
  question       Question          @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption    @relation(fields: [selectedOptionId], references: [id])

  // One answer per question per session
  @@unique([sessionId, questionId])
  @@map("session_responses")
}

/// Pillar-level score and insight for a session.
/// One row per pillar per session — 7 rows total for a full Phase 1 run.
model SessionPillarScore {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  pillarId  String @map("pillar_id")

  rawScore         Int     @map("raw_score") // sum of selected scores
  maxPossibleScore Int     @map("max_possible_score") // sum of max scores for answered Qs
  weightedScore    Decimal @map("weighted_score") @db.Decimal(6, 2) // 0–100

  hasKnockout Boolean   @default(false) @map("has_knockout")
  colorBand   ColorBand @map("color_band")

  insightRuleApplied InsightRule @map("insight_rule_applied")

  // ─── Findings stored as JSON ──────────────────────────────
  // Array of 1–2 findings selected by the rule above.
  // Shape per item:
  // {
  //   optionId:       string,
  //   questionText:   string,
  //   selectedLabel:  string,   // "A" | "B" | "C" | "D"
  //   observation:    string,
  //   recommendation: string,
  //   riskType:       RiskType,
  //   score:          number
  // }
  findings Json // Json[] shape described above

  // Relations
  session AssessmentSession @relation(fields: [sessionId], references: [id])
  pillar  Pillar            @relation(fields: [pillarId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sessionId, pillarId]) // one score row per pillar per session
  @@map("session_pillar_scores")
}

/// Overall session result — one row per completed session.
model SessionResult {
  id        String @id @default(uuid())
  sessionId String @unique @map("session_id") // 1:1 with AssessmentSession

  totalScore     Decimal   @map("total_score") @db.Decimal(6, 2) // 0–100
  colorBand      ColorBand @map("color_band")
  hasAnyKnockout Boolean   @default(false) @map("has_any_knockout")

  // Array of question_ids that triggered a knockout, e.g. ["uuid-1", "uuid-2"]
  knockoutQuestionIds Json @map("knockout_question_ids")

  insightPayload Json @map("insight_payload")

  // Populated after payment + PDF generation
  reportPdfUrl    String?   @map("report_pdf_url")
  generatedAt     DateTime? @map("generated_at")
  isPaid          Boolean   @default(false) @map("is_paid")
  paidAt          DateTime? @map("paid_at")
  paidByPaymentId String?   @unique @map("paid_by_payment_id")

  // Relations
  session AssessmentSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("session_results")
}

// ============================================================
// LAYER D — PAYMENTS
// ============================================================

/// One Payment row per Paystack initialization.
/// Created when the FE hits /api/payment/init (status PENDING) and updated by
/// either the verify endpoint or the webhook (status SUCCESS/FAILED/etc).
/// `providerReference` is unique so retries on the same Paystack reference
/// idempotently update the same row instead of duplicating.
model Payment {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  // PHASE2A: required (set at init time, identifies the SessionResult being paid for).
  // PHASE2B_PILLAR: null (no session exists yet at payment time; pillarId is set instead).
  sessionId String? @map("session_id")
  // PHASE2B_PILLAR: required (the pillar being unlocked).
  // PHASE2A: null.
  pillarId  String? @map("pillar_id")

  plan     Plan
  provider PaymentProvider @default(PAYSTACK)

  // Paystack
  providerReference String  @unique @map("provider_reference") // Paystack `reference`
  accessCode        String? @map("access_code") // Paystack init response
  authorizationUrl  String? @map("authorization_url") // Paystack init response

  // Amount in MAJOR units (NGN) for readability.
  // Paystack works in kobo; convert at the boundary.
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("NGN")

  status        PaymentStatus @default(PENDING)
  paymentMethod String?       @map("payment_method") // "card" | "bank" | "ussd" | "qr" | "transfer" | etc.
  paidAt        DateTime?     @map("paid_at")
  failureReason String?       @map("failure_reason")

  // Snapshot of customer details at init time so the admin transaction page
  // shows the exact business name / email at the moment of payment, even if
  // the user later changes them.
  customerEmail        String  @map("customer_email")
  customerBusinessName String? @map("customer_business_name")

  // Raw provider responses kept for forensics. Not exposed via list endpoints.
  initPayload   Json? @map("init_payload")
  verifyPayload Json? @map("verify_payload")

  // Relations
  user          User                 @relation(fields: [userId], references: [id])
  pillar        Pillar?              @relation(fields: [pillarId], references: [id])
  webhookEvents WebhookEvent[]
  phase2bUnlock Phase2BPillarUnlock?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@map("payments")
}

/// Append-only log of every webhook the provider sends us.
/// Idempotent on (provider, providerEventId) — Paystack retries the same event
/// id, so we ack but skip re-processing.
model WebhookEvent {
  id String @id @default(uuid())

  provider        PaymentProvider
  providerEventId String          @map("provider_event_id") // Paystack event signature/id
  eventType       String          @map("event_type") // "charge.success" etc.
  signatureValid  Boolean         @default(false) @map("signature_valid")

  // Resolved Payment row (by reference) — null if we couldn't match yet.
  paymentId String?  @map("payment_id")
  payment   Payment? @relation(fields: [paymentId], references: [id])

  rawBody Json @map("raw_body") // full event body for forensics

  processingStatus WebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  processingError  String?                 @map("processing_error")
  processedAt      DateTime?               @map("processed_at")

  receivedAt DateTime @default(now()) @map("received_at")

  @@unique([provider, providerEventId])
  @@index([eventType])
  @@map("webhook_events")
}

// ============================================================
// LAYER E — PHASE 2B ENTITLEMENTS
// ============================================================

/// One row per successful Phase 2B pillar purchase.
///
/// Lifecycle:
///   1. POST /api/payment/init (plan PHASE2B_PILLAR) creates a Payment.
///   2. On verify/webhook SUCCESS, an unlock row is created with
///      sessionId = null. The user now holds a redeemable credit for that
///      pillar.
///   3. POST /api/assessment/phase2b/start claims the unlock, creating a
///      new AssessmentSession and setting unlock.sessionId.
///   4. POST /api/assessment/:sessionId/submit consumes the unlock:
///      consumedAt is set, the linked SessionResult.isPaid flips to true
///      (so the existing result/PDF code path works without 2B-specific
///      branching).
///
/// "One open unlock per (user, pillar)" is enforced in application code
/// (see initPaymentService) rather than via a DB partial-unique index —
/// users can have many historical CONSUMED unlocks for the same pillar
/// (retakes), so the constraint only applies to rows where consumedAt IS NULL.
///
/// Refund policy: PaymentStatus.REVERSED is recorded but does NOT delete or
/// re-open the unlock. Per anti-fraud policy.
model Phase2BPillarUnlock {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  pillarId   String    @map("pillar_id")
  paymentId  String    @unique @map("payment_id") // the SUCCESS Payment that granted this
  sessionId  String?   @unique @map("session_id") // null = unstarted; set when user starts test
  unlockedAt DateTime  @default(now()) @map("unlocked_at")
  consumedAt DateTime? @map("consumed_at") // set when the session is submitted

  // Relations
  user    User               @relation(fields: [userId], references: [id])
  pillar  Pillar             @relation(fields: [pillarId], references: [id])
  payment Payment            @relation(fields: [paymentId], references: [id])
  session AssessmentSession? @relation(fields: [sessionId], references: [id])

  // Open-unlock lookup is hot (every init payment + every start session
  // hits this index).
  @@index([userId, pillarId])
  @@map("phase2b_pillar_unlocks")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Phase {
  PHASE1
  PHASE2A
  PHASE2B
}

enum RiskType {
  NORMAL
  RISK
  KNOCKOUT
}

enum ColorBand {
  RED
  AMBER
  GREEN
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  PAID
  REPORT_GENERATED
}

enum InsightRule {
  KNOCKOUT
  BOTH_RISK
  ONE_RISK
  BOTH_NORMAL
}

enum BusinessSize {
  SMALL
  MEDIUM
}

enum Plan {
  PHASE2A
  PHASE2B_PILLAR
  /// Recurring subscription charge — used for both the first charge and every
  /// renewal. The Payment row is the audit trail; the UserSubscription row
  /// (via `userSubscriptionId`) is the entitlement. grantSuccessEntitlements
  /// short-circuits for SUBSCRIPTION rows because there's nothing to unlock.
  SUBSCRIPTION
  /// One-off consultation paywall. Paid when the user has no consultation
  /// quota left on their subscription. The Payment row is linked to a
  /// ConsultationBooking via Payment.consultationBookingId; grant logic flips
  /// the booking from REQUESTED-pending-payment to REQUESTED-confirmable.
  CONSULTATION
}

/// Lifecycle of a consultation booking.
///   REQUESTED — user submitted; either covered by subscription quota or
///               waiting for paywall completion. Visible to admin in either
///               case (Payment.status acts as the "ready to confirm" gate).
///   CONFIRMED — admin set scheduledAt + meetingLink, user notified.
///   ATTENDED  — admin marked complete after the session.
///   NO_SHOW   — admin recorded the user didn't show.
///   CANCELLED — user-cancelled OR admin-cancelled (preserves the audit row).
enum ConsultationBookingStatus {
  REQUESTED
  CONFIRMED
  ATTENDED
  NO_SHOW
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
  REVERSED
}

enum PaymentProvider {
  PAYSTACK
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

// Account standing. DISABLED users cannot log in, and any live access token
// is rejected by the auth middleware on the next request (the middleware
// re-checks status in the DB), so suspension takes effect immediately.
enum UserStatus {
  ACTIVE
  DISABLED
}

// Subscription lifecycle. Mirrors Paystack's `subscription` statuses but only
// names the ones our flows actually act on. The remaining Paystack states
// (e.g. "non-renewing", "attention") collapse to PAST_DUE or CANCELLED based
// on whether the user can still consume quota.
enum SubscriptionStatus {
  ACTIVE     // current period valid, quota consumable
  PAST_DUE   // renewal charge failed; access until period end then EXPIRED
  CANCELLED  // user (or admin) ended it; access until period end if cancelAtPeriodEnd
  EXPIRED    // no current period; user must resubscribe
}

// The seven fixed pillar codes. Used as the canonical identifier for a Pillar
// and as the prefix of every questionCode (e.g. "FL-001"). Keeping it an enum
// guarantees consistent naming across pillars and admin-created questions.
enum PillarCode {
  FL
  FR
  BM
  OP
  MS
  GC
  SS
}

// ============================================================
// LAYER A — CONTENT (Static / Admin-Managed)
// ============================================================

model Pillar {
  id           String     @id @default(uuid())
  code         PillarCode @unique // e.g. "FL", "FR", "BM", "OP", "MS", "GC", "SS"
  name         String // e.g. "Founder & Leadership"
  description  String?
  weight       Decimal    @db.Decimal(5, 2) // e.g. 14.28 for equal 7-pillar weighting
  displayOrder Int        @map("display_order")
  isActive     Boolean    @default(true) @map("is_active")

  // Relations
  questions           Question[]
  sessionPillarScores SessionPillarScore[]
  // Phase 2B: a payment / session / unlock can be scoped to one pillar.
  payments            Payment[]
  sessions            AssessmentSession[]
  phase2bUnlocks      Phase2BPillarUnlock[]
  planPrices          PlanPrice[]
  discounts           Discount[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pillars")
}

/// Singleton (one row) — admin-editable RED/AMBER/GREEN color-band thresholds
/// plus display label/description per band. Read by the scoring engine at
/// submit time, so edits only affect future submissions: every saved result
/// keeps the band that was computed when it was scored.
///   score >= greenMin           → GREEN
///   score >= amberMin           → AMBER
///   score <  amberMin           → RED
/// Invariant (enforced in the service): 0 < amberMin < greenMin <= 100.
model ScoringSettings {
  id String @id @default(uuid())

  amberMin Decimal @map("amber_min") @db.Decimal(5, 2) // default 50
  greenMin Decimal @map("green_min") @db.Decimal(5, 2) // default 80

  redLabel         String @default("Urgent attention") @map("red_label")
  redDescription   String @default("Critical gaps that need immediate action.") @map("red_description")
  amberLabel       String @default("Needs work") @map("amber_label")
  amberDescription String @default("Improving, but key risks remain.") @map("amber_description")
  greenLabel       String @default("Healthy") @map("green_label")
  greenDescription String @default("Strong performance — keep it up.") @map("green_description")

  phase2aQuestionLimit Int @default(40) @map("phase2a_question_limit")
  phase2bQuestionLimit Int @default(30) @map("phase2b_question_limit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("scoring_settings")
}

/// Singleton (one row) — admin-editable app-wide settings. Today this owns the
/// USD→NGN exchange rate used to display/charge Nigerian users in Naira while
/// non-NG users see USD. Kept as its own table (rather than bolted onto
/// ScoringSettings) because the lifecycle and ownership are different.
/// `updatedBy` is the admin User.id so we can attribute rate changes.
model AppSettings {
  id String @id @default(uuid())

  // Rate to convert USD (base) → NGN at display/charge time. Decimal(12, 4)
  // gives 4dp precision, enough for any realistic FX value; the seed below
  // installs a reasonable starting rate that the admin is expected to update.
  usdToNgn Decimal @map("usd_to_ngn") @db.Decimal(12, 4)

  // Storefront section toggles for the public pricing page (Section F).
  // Both default to true so the page renders as-is until an admin flips one
  // off. The service layer enforces the "at least one section must stay
  // live" invariant — turning both off at once is rejected.
  payPerUseActive   Boolean @default(true) @map("pay_per_use_active")
  subscriptionActive Boolean @default(true) @map("subscription_active")

  updatedBy String? @map("updated_by")
  updatedByUser User? @relation("AppSettingsUpdatedBy", fields: [updatedBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model Question {
  id                String       @id @default(uuid())
  pillarId          String       @map("pillar_id")
  questionCode      String       @unique @map("question_code") // e.g. "FL-001"
  questionText      String       @map("question_text")
  // A single question can serve both phases. Phase 2A draws from the full active set
  // for the user's businessSize; Phase 1 surfaces only those flagged isPhase1Featured.
  businessSize      BusinessSize @map("business_size")
  isPhase1Featured  Boolean      @default(false) @map("is_phase1_featured")
  // Which deep-dive phase this question belongs to.
  //   PHASE2A — Phase 1 and Phase 2A draw from these rows.
  //   PHASE2B — pillar-specific deep-dive content, surfaced only when a user
  //             starts a Phase 2B session for the matching pillar.
  // Existing rows default to PHASE2A so the migration is non-destructive.
  phase             Phase        @default(PHASE2A) @map("phase")
  displayOrder      Int          @map("display_order")
  hasKnockoutOption Boolean      @default(false) @map("has_knockout_option")
  isActive          Boolean      @default(true) @map("is_active")

  // Relations
  pillar    Pillar            @relation(fields: [pillarId], references: [id])
  options   QuestionOption[]
  responses SessionResponse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

model QuestionOption {
  id             String   @id @default(uuid())
  questionId     String   @map("question_id")
  optionLabel    String   @map("option_label") // "A", "B", "C", "D"
  optionText     String   @map("option_text")
  score          Int // 0, 3, 5, 6, 7, 10
  riskType       RiskType @map("risk_type")
  observation    String // e.g. "High focus"
  recommendation String // e.g. "Maintain this; you are in the Growth Zone"
  displayOrder   Int      @map("display_order")

  // Relations
  question  Question          @relation(fields: [questionId], references: [id])
  responses SessionResponse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([questionId, optionLabel]) // no duplicate A/B/C/D per question
  @@map("question_options")
}

// ============================================================
// LAYER B — USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash") // null for Phase 1 lead-only users
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  businessName String?  @map("business_name")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isVerified   Boolean  @default(false) @map("is_verified")
  role         UserRole @default(USER)
  status       UserStatus @default(ACTIVE)

  // Per-admin access control. `permissions` is this admin's own granular
  // permission set (chosen at invite time); `department` is an org label
  // ("Finance", "Audit", "SUPER ADMIN", or custom). For ADMIN users these are
  // the source of truth — the legacy adminRole relation is only a fallback for
  // admins onboarded before per-person permissions existed.
  permissions  String[] @default([])
  department   String?

  // Snapshotted from the originating Phase 1 AssessmentSession at registration.
  // Source of truth for Phase 2A `businessSize` filtering.
  businessSize   BusinessSize? @map("business_size")
  staffSize      String?       @map("staff_size")
  industry       String?
  country        String?
  state          String?
  operatingYears String?       @map("operating_years")
  annualRevenue  String?       @map("annual_revenue_range")

  // Relations
  sessions       AssessmentSession[]
  payments       Payment[]
  phase2bUnlocks Phase2BPillarUnlock[]
  discounts      Discount[]
  adminRoleId    String?               @map("admin_role_id")
  adminRole      AdminRole?            @relation(fields: [adminRoleId], references: [id])
  // Reverse side of AppSettings.updatedBy — kept here only so the relation
  // type-checks; admins shouldn't need to enumerate the AppSettings rows they
  // edited (there's only one row anyway).
  appSettingsUpdates AppSettings[]      @relation("AppSettingsUpdatedBy")
  subscriptions      UserSubscription[]
  consultations      ConsultationBooking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================================
// LAYER C — SESSION (Per User Assessment Run)
// ============================================================

model AssessmentSession {
  id     String        @id @default(uuid())
  userId String?       @map("user_id")
  phase  Phase
  status SessionStatus @default(IN_PROGRESS)

  // Phase 2B only — the pillar being deep-dived. Null for PHASE1 / PHASE2A.
  pillarId String? @map("pillar_id")

  // Phase 1 lead capture fields (filled before account creation)
  leadEmail      String?       @unique @map("lead_email")
  staffSize      String?       @map("lead_staff_size")
  businessName   String        @map("lead_business_name")
  industry       String        @map("lead_industry")
  location       String        @map("lead_location")
  operatingYears String        @map("lead_operating_years")
  annualRevenue  String        @map("lead_annual_revenue_range")
  businessSize   BusinessSize? @map("business_size")

  // Phase 2A snapshot: array of question UUIDs (length = 7 pillars × 10 = 70)
  // Frozen on Phase 2A start so admin edits to questions mid-session do not change the user's set.
  selectedQuestionIds Json? @map("selected_question_ids")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user          User?                @relation(fields: [userId], references: [id])
  pillar        Pillar?              @relation(fields: [pillarId], references: [id])
  responses     SessionResponse[]
  pillarScores  SessionPillarScore[]
  result        SessionResult?
  phase2bUnlock Phase2BPillarUnlock?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("assessment_sessions")
}

model SessionResponse {
  id               String @id @default(uuid())
  sessionId        String @map("session_id")
  questionId       String @map("question_id")
  selectedOptionId String @map("selected_option_id")

  // Captured at answer time so reports are immune to future admin edits on the question/option content.
  scoreAtTime    Int      @map("score_at_time")
  riskTypeAtTime RiskType @map("risk_type_at_time")

  answeredAt DateTime @default(now()) @map("answered_at")

  // Relations
  session        AssessmentSession @relation(fields: [sessionId], references: [id])
  question       Question          @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption    @relation(fields: [selectedOptionId], references: [id])

  // One answer per question per session
  @@unique([sessionId, questionId])
  @@map("session_responses")
}

/// Pillar-level score and insight for a session.
/// One row per pillar per session — 7 rows total for a full Phase 1 run.
model SessionPillarScore {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  pillarId  String @map("pillar_id")

  rawScore         Int     @map("raw_score") // sum of selected scores
  maxPossibleScore Int     @map("max_possible_score") // sum of max scores for answered Qs
  weightedScore    Decimal @map("weighted_score") @db.Decimal(6, 2) // 0–100

  hasKnockout Boolean   @default(false) @map("has_knockout")
  colorBand   ColorBand @map("color_band")

  insightRuleApplied InsightRule @map("insight_rule_applied")

  // ─── Findings stored as JSON ──────────────────────────────
  // Array of 1–2 findings selected by the rule above.
  // Shape per item:
  // {
  //   optionId:       string,
  //   questionText:   string,
  //   selectedLabel:  string,   // "A" | "B" | "C" | "D"
  //   observation:    string,
  //   recommendation: string,
  //   riskType:       RiskType,
  //   score:          number
  // }
  findings Json // Json[] shape described above

  // Relations
  session AssessmentSession @relation(fields: [sessionId], references: [id])
  pillar  Pillar            @relation(fields: [pillarId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sessionId, pillarId]) // one score row per pillar per session
  @@map("session_pillar_scores")
}

/// Overall session result — one row per completed session.
model SessionResult {
  id        String @id @default(uuid())
  sessionId String @unique @map("session_id") // 1:1 with AssessmentSession

  totalScore     Decimal   @map("total_score") @db.Decimal(6, 2) // 0–100
  colorBand      ColorBand @map("color_band")
  hasAnyKnockout Boolean   @default(false) @map("has_any_knockout")

  // Array of question_ids that triggered a knockout, e.g. ["uuid-1", "uuid-2"]
  knockoutQuestionIds Json @map("knockout_question_ids")

  insightPayload Json @map("insight_payload")

  // Populated after payment + PDF generation
  reportPdfUrl    String?   @map("report_pdf_url")
  generatedAt     DateTime? @map("generated_at")
  isPaid          Boolean   @default(false) @map("is_paid")
  paidAt          DateTime? @map("paid_at")
  paidByPaymentId String?   @unique @map("paid_by_payment_id")

  // Relations
  session              AssessmentSession     @relation(fields: [sessionId], references: [id])
  consultationBookings ConsultationBooking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("session_results")
}

// ============================================================
// LAYER D — PAYMENTS
// ============================================================

/// One Payment row per Paystack initialization.
/// Created when the FE hits /api/payment/init (status PENDING) and updated by
/// either the verify endpoint or the webhook (status SUCCESS/FAILED/etc).
/// `providerReference` is unique so retries on the same Paystack reference
/// idempotently update the same row instead of duplicating.
model Payment {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  // PHASE2A: required (set at init time, identifies the SessionResult being paid for).
  // PHASE2B_PILLAR: null (no session exists yet at payment time; pillarId is set instead).
  sessionId String? @map("session_id")
  // PHASE2B_PILLAR: required (the pillar being unlocked).
  // PHASE2A: null.
  pillarId  String? @map("pillar_id")
  // SUBSCRIPTION: required (the UserSubscription this charge funds).
  // PHASE2A / PHASE2B_PILLAR: null.
  userSubscriptionId String? @map("user_subscription_id")
  // CONSULTATION: required (the ConsultationBooking this paywall row funds).
  // All other plans: null. Booking is created REQUESTED up front and becomes
  // "ready to confirm" once Payment.status = SUCCESS.
  consultationBookingId String? @unique @map("consultation_booking_id")

  plan     Plan
  provider PaymentProvider @default(PAYSTACK)

  // Paystack
  providerReference String  @unique @map("provider_reference") // Paystack `reference`
  accessCode        String? @map("access_code") // Paystack init response
  authorizationUrl  String? @map("authorization_url") // Paystack init response

  // Amount in MAJOR units of `currency` — this is the FINAL charged amount
  // after any coupon discount. Paystack works in kobo (NGN) or cents (USD);
  // convert at the boundary. `currency` is the wire currency the user was
  // actually billed in (NGN for Nigerian users, USD for everyone else).
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("USD")

  // The USD-equivalent of `amount` at charge time. Lets admin roll-ups and
  // analytics aggregate revenue in one currency even when individual rows
  // span NGN and USD. For USD charges this equals `amount`; for NGN charges
  // it is `amount / usdToNgn` snapshotted from app_settings at init time.
  amountUsd Decimal? @map("amount_usd") @db.Decimal(12, 2)

  // Coupon applied at init time (if any). discountAmount is in the same major
  // units as `amount` (whichever currency the user was charged in). Both null
  // when no coupon was used. Kept for the admin transactions view / audit.
  appliedCouponCode String?  @map("applied_coupon_code")
  discountAmount    Decimal? @map("discount_amount") @db.Decimal(12, 2)

  status        PaymentStatus @default(PENDING)
  paymentMethod String?       @map("payment_method") // "card" | "bank" | "ussd" | "qr" | "transfer" | etc.
  paidAt        DateTime?     @map("paid_at")
  failureReason String?       @map("failure_reason")

  // Snapshot of customer details at init time so the admin transaction page
  // shows the exact business name / email at the moment of payment, even if
  // the user later changes them.
  customerEmail        String  @map("customer_email")
  customerBusinessName String? @map("customer_business_name")

  // Raw provider responses kept for forensics. Not exposed via list endpoints.
  initPayload   Json? @map("init_payload")
  verifyPayload Json? @map("verify_payload")

  // Relations
  user                 User                  @relation(fields: [userId], references: [id])
  pillar               Pillar?               @relation(fields: [pillarId], references: [id])
  userSubscription     UserSubscription?     @relation(fields: [userSubscriptionId], references: [id])
  consultationBooking  ConsultationBooking?  @relation(fields: [consultationBookingId], references: [id])
  webhookEvents        WebhookEvent[]
  phase2bUnlock        Phase2BPillarUnlock?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([userSubscriptionId])
  @@map("payments")
}

/// Append-only log of every webhook the provider sends us.
/// Idempotent on (provider, providerEventId) — Paystack retries the same event
/// id, so we ack but skip re-processing.
model WebhookEvent {
  id String @id @default(uuid())

  provider        PaymentProvider
  providerEventId String          @map("provider_event_id") // Paystack event signature/id
  eventType       String          @map("event_type") // "charge.success" etc.
  signatureValid  Boolean         @default(false) @map("signature_valid")

  // Resolved Payment row (by reference) — null if we couldn't match yet.
  paymentId String?  @map("payment_id")
  payment   Payment? @relation(fields: [paymentId], references: [id])

  rawBody Json @map("raw_body") // full event body for forensics

  processingStatus WebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  processingError  String?                 @map("processing_error")
  processedAt      DateTime?               @map("processed_at")

  receivedAt DateTime @default(now()) @map("received_at")

  @@unique([provider, providerEventId])
  @@index([eventType])
  @@map("webhook_events")
}

// ============================================================
// LAYER E — PHASE 2B ENTITLEMENTS
// ============================================================

/// One row per successful Phase 2B pillar purchase.
///
/// Lifecycle:
///   1. POST /api/payment/init (plan PHASE2B_PILLAR) creates a Payment.
///   2. On verify/webhook SUCCESS, an unlock row is created with
///      sessionId = null. The user now holds a redeemable credit for that
///      pillar.
///   3. POST /api/assessment/phase2b/start claims the unlock, creating a
///      new AssessmentSession and setting unlock.sessionId.
///   4. POST /api/assessment/:sessionId/submit consumes the unlock:
///      consumedAt is set, the linked SessionResult.isPaid flips to true
///      (so the existing result/PDF code path works without 2B-specific
///      branching).
///
/// "One open unlock per (user, pillar)" is enforced in application code
/// (see initPaymentService) rather than via a DB partial-unique index —
/// users can have many historical CONSUMED unlocks for the same pillar
/// (retakes), so the constraint only applies to rows where consumedAt IS NULL.
///
/// Refund policy: PaymentStatus.REVERSED is recorded but does NOT delete or
/// re-open the unlock. Per anti-fraud policy.
model Phase2BPillarUnlock {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  pillarId   String    @map("pillar_id")
  paymentId  String    @unique @map("payment_id") // the SUCCESS Payment that granted this
  sessionId  String?   @unique @map("session_id") // null = unstarted; set when user starts test
  unlockedAt DateTime  @default(now()) @map("unlocked_at")
  consumedAt DateTime? @map("consumed_at") // set when the session is submitted

  // Relations
  user    User               @relation(fields: [userId], references: [id])
  pillar  Pillar             @relation(fields: [pillarId], references: [id])
  payment Payment            @relation(fields: [paymentId], references: [id])
  session AssessmentSession? @relation(fields: [sessionId], references: [id])

  // Open-unlock lookup is hot (every init payment + every start session
  // hits this index).
  @@index([userId, pillarId])
  @@map("phase2b_pillar_unlocks")
}

// PLAN PRICES (authoritative payment pricing; admin-managed and read by checkout)

model PlanPrice {
  id       String  @id @default(uuid())
  plan     Plan
  // null for PHASE2A; the specific Pillar for PHASE2B_PILLAR (per-pillar pricing).
  pillarId String? @map("pillar_id")
  price    Decimal @db.Decimal(12, 2) // in MAJOR units (NGN)

  pillar Pillar? @relation(fields: [pillarId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // One price per (plan, pillar). For PHASE2A pillarId is null → a single 2A row.
  @@unique([plan, pillarId])
  @@map("plan_prices")
}

model Discount {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?
  // Both are always stored: the admin enters one, the FE derives the other, and
  // the backend cross-verifies the pair on redemption.
  amountOff   Decimal @db.Decimal(12, 2) @map("amount_off") // absolute discount in MAJOR units (NGN)
  percentOff  Decimal @db.Decimal(5, 2)  @map("percent_off") // percentage discount (0–100)
  isActive    Boolean @default(true) @map("is_active")
  status      String  @default("ACTIVE")

  // Usage limits. maxUses = how many distinct redemptions the code allows
  // (defaults to 1 so a forgotten field can't create an unlimited promo);
  // usedCount tracks SUCCESS redemptions so far. When usedCount reaches
  // maxUses the status flips to USED. A user-scoped coupon (userId set) is
  // always maxUses = 1. Per-user reuse is blocked via the payments table
  // (one SUCCESS payment per user per code), not a column here.
  maxUses     Int     @default(1) @map("max_uses")
  usedCount   Int     @default(0) @map("used_count")
  userId      String? @map("user_id") // optional link to a User for user-specific discounts
  plan        Plan? // optional target plan; null = usable on any paid plan
  pillarId    String? @map("pillar_id") // PHASE2B_PILLAR target; null for global/PHASE2A coupons

  user User? @relation(fields: [userId], references: [id])
  pillar Pillar? @relation(fields: [pillarId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([plan, pillarId])
  @@map("discounts")
}

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[]
  users       User[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_roles")
}

// ============================================================
// LAYER E — SUBSCRIPTIONS (Paystack recurring, 3 tiers)
// ============================================================

/// Admin-defined subscription tier. Three rows are seeded by the migration —
/// Starter / Growth / Scale — and the admin can edit every field below. The
/// description renders inline with the feature list on the dashboard card.
///
/// Paystack Plans are per-currency, so each tier carries TWO plan codes: one
/// for NGN-billed users and one for USD-billed users. The codes are populated
/// by the admin create/update path after it calls Paystack; nullable so a
/// row can exist briefly between insert and the Paystack round-trip.
model SubscriptionPlan {
  id String @id @default(uuid())

  // Display tier (1 = Starter, 2 = Growth, 3 = Scale). An int rather than an
  // enum so the admin can re-order or add tiers without a schema migration.
  tier        Int
  name        String
  description String  @default("")
  priceUsd    Decimal @map("price_usd") @db.Decimal(12, 2)

  // Monthly quotas — what one period of this subscription buys. 0 means the
  // tier doesn't include that benefit (e.g. a future "view-only" tier).
  phase2aPerMonth        Int @map("phase2a_per_month")
  phase2bPerMonth        Int @map("phase2b_per_month")
  consultationsPerMonth  Int @map("consultations_per_month")

  // Feature bullets shown on the storefront card. Stored as text[] so the
  // admin can re-order them; the dashboard renders these *after* `description`
  // on the same card.
  features String[] @default([])

  // Paystack-side plan codes, one per wire currency. Populated by the admin
  // create/update flow via paystack.service.createPlan; null only in the brief
  // window before that call returns.
  paystackPlanCodeUsd String? @map("paystack_plan_code_usd")
  paystackPlanCodeNgn String? @map("paystack_plan_code_ngn")

  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0)    @map("display_order")

  subscriptions UserSubscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("subscription_plans")
}

/// One row per user-subscription lifecycle. New row on every fresh subscribe;
/// the renewal webhook rolls `currentPeriodStart/End` in place rather than
/// creating new rows so a single UserSubscription represents the whole
/// relationship with Paystack until cancelled.
model UserSubscription {
  id     String @id @default(uuid())
  userId String @map("user_id")
  planId String @map("plan_id")

  status SubscriptionStatus @default(ACTIVE)

  // Paystack identifiers — `subscriptionCode` is what we call cancel/disable
  // against; `customerCode` is reusable across subscriptions for the same user.
  // `emailToken` is required by Paystack disable but only known after the
  // first subscription.create webhook lands.
  paystackSubscriptionCode String? @unique @map("paystack_subscription_code")
  paystackCustomerCode     String? @map("paystack_customer_code")
  paystackEmailToken       String? @map("paystack_email_token")

  // The currency this subscription is billed in. Locked at subscribe time —
  // changing currency requires cancelling and resubscribing because Paystack
  // Plans are currency-specific.
  currency String @default("USD")

  // Card-on-file snapshot for the Settings → Payments screen. Paystack
  // returns these on the first charge.success in `data.authorization`. We
  // ONLY store masked / non-PAN fields — last4, type, bank, expiry — plus
  // the reusable `authorizationCode` token that Paystack uses for charging
  // future renewals on the same card. Never the full PAN, never the CVV.
  cardLast4              String? @map("card_last4")
  cardBrand              String? @map("card_brand")
  cardBank               String? @map("card_bank")
  cardExpMonth           String? @map("card_exp_month")
  cardExpYear            String? @map("card_exp_year")
  cardAuthorizationCode  String? @map("card_authorization_code")

  // Current billing period. Rolled forward by the charge.success webhook on
  // each successful renewal. EXPIRED rows still carry the last period for
  // audit; new periods are gated on status === ACTIVE.
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  // If true, the subscription stops at the next period end (user clicked
  // cancel mid-period). The actual flip to EXPIRED happens when Paystack
  // sends `subscription.disable` or the period rolls past `currentPeriodEnd`.
  cancelAtPeriodEnd Boolean @default(false) @map("cancel_at_period_end")

  user     User              @relation(fields: [userId], references: [id])
  plan     SubscriptionPlan  @relation(fields: [planId], references: [id])
  usage    SubscriptionUsage[]
  payments Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("user_subscriptions")
}

/// Per-period usage counters. A new row is created at the start of each
/// billing period (subscribe + every successful renewal); old rows are kept
/// so we can show the user a history of what they consumed when.
///
/// `(userSubscriptionId, periodStart)` is unique — the renewal webhook is
/// idempotent and the upsert here is what guards against duplicate periods
/// if Paystack ever delivers the same event twice past WebhookEvent dedupe.
model SubscriptionUsage {
  id                   String @id @default(uuid())
  userSubscriptionId   String @map("user_subscription_id")

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  phase2aUsed       Int @default(0) @map("phase2a_used")
  phase2bUsed       Int @default(0) @map("phase2b_used")
  consultationsUsed Int @default(0) @map("consultations_used")

  userSubscription UserSubscription @relation(fields: [userSubscriptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userSubscriptionId, periodStart])
  @@index([userSubscriptionId, periodEnd])
  @@map("subscription_usage")
}

// ============================================================
// LAYER F — CONSULTATIONS (Section E)
// ============================================================
//
// One-off advisory calls. Unlike subscription plans, ConsultationTier rows
// are NOT mirrored to Paystack — every booking that needs payment generates a
// fresh one-off transaction via initializeTransaction (same path as Phase 2A
// / 2B). The tier is a price + duration template; the booking is the actual
// event.
//
// Quota integration: subscribers consume `consultationsPerMonth` from their
// active UserSubscription via assertSubscriptionQuota('consultation'). If
// quota is available, the booking is coveredBySubscription=true with no
// Payment row attached. Otherwise a paywall Payment is created and the
// booking sits in REQUESTED until the Payment lands as SUCCESS.

/// Admin-defined consultation tier (e.g. 30min / 60min / 90min). Prices are
/// USD-base like subscription plans; NGN users see the converted price at
/// checkout via the same FX rate.
model ConsultationTier {
  id String @id @default(uuid())

  tier         Int
  name         String
  description  String  @default("")
  priceUsd     Decimal @map("price_usd") @db.Decimal(12, 2)
  durationMinutes Int  @map("duration_minutes")

  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0)    @map("display_order")

  bookings ConsultationBooking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("consultation_tiers")
}

/// One row per request. Created in REQUESTED state as soon as the user
/// submits — quota path keeps it as-is, paywall path attaches a Payment via
/// Payment.consultationBookingId. The booking stays REQUESTED until the
/// admin confirms (sets scheduledAt + meetingLink); subsequent state changes
/// are ATTENDED / NO_SHOW / CANCELLED.
model ConsultationBooking {
  id     String @id @default(uuid())
  userId String @map("user_id")
  tierId String @map("tier_id")

  status ConsultationBookingStatus @default(REQUESTED)

  // Form fields. `topic` is short ("hiring plan review"); `notes` is the
  // longer-form context the consultant wants to read before the call.
  // `preferredTimes` is free-form for now (user types like "Mon AM, Wed
  // afternoon") — kept simple; we don't try to parse it.
  topic          String
  notes          String  @default("")
  preferredTimes String? @map("preferred_times")

  // Optional link back to the SessionResult the user wants to discuss. The
  // form populates this from the user's completed+paid Phase 2A / Phase 2B
  // results so the consultant lands with context.
  relatedSessionResultId String? @map("related_session_result_id")

  // Admin-set after confirm.
  scheduledAt DateTime? @map("scheduled_at")
  meetingLink String?   @map("meeting_link")

  // Quota path: true when a subscription consultation slot was consumed.
  // No Payment row exists in that case; the entitlement IS the
  // SubscriptionUsage decrement.
  coveredBySubscription Boolean @default(false) @map("covered_by_subscription")

  // Paywall path: linked Payment row. The Payment.consultationBookingId
  // side is @unique, so this is effectively 1:1 from the booking side too.
  // Read via `payment` relation rather than carrying paymentId here.

  requestedAt DateTime @default(now()) @map("requested_at")

  // Relations
  user           User           @relation(fields: [userId], references: [id])
  tier           ConsultationTier @relation(fields: [tierId], references: [id])
  relatedResult  SessionResult? @relation(fields: [relatedSessionResultId], references: [id])
  payment        Payment?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([status, requestedAt])
  @@map("consultation_bookings")
}
